<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- ============================================================
	     Mallow (native) — macOS app bundle Info.plist
	     Used by build-app.sh to assemble .build/Mallow.app.
	     Bundle id is DISTINCT from the old Tauri build so the two never
	     collide in LaunchServices / TCC.
	     ============================================================ -->

	<key>CFBundleName</key>
	<string>Mallow</string>
	<key>CFBundleDisplayName</key>
	<string>Mallow</string>

	<!-- Distinct from the old Tauri build on purpose. -->
	<key>CFBundleIdentifier</key>
	<string>com.gurumdeva.mallow-native</string>

	<!-- Must match the file copied to Contents/MacOS/ by build-app.sh. -->
	<key>CFBundleExecutable</key>
	<string>Mallow</string>

	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>

	<!-- Declare the languages the app supports so AppKit localizes its STANDARD menus (the app menu —
	     About/Hide/Quit; the standard Edit items — Undo/Cut/Copy/Paste/Select All; Window; Help; "Enter
	     Full Screen"; and the standard menu titles File/Edit/View/Window/Help) to the device language,
	     matching the app's own strings (L.t, which resolves from Locale.preferredLanguages). Without this
	     the bundle's only localization is the development region (en) and AppKit renders all that chrome
	     in English even on a Korean/Japanese system. The app's own UI strings are localized in code
	     (Services/Localization.swift), so no per-language .lproj resources are needed. -->
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>en</string>
		<string>ko</string>
		<string>ja</string>
	</array>

	<key>CFBundleShortVersionString</key>
	<string>1.2.5</string>
	<key>CFBundleVersion</key>
	<string>31</string>

	<key>LSMinimumSystemVersion</key>
	<string>14.0</string>

	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>

	<!-- This is an editor with no agent/background role; show normally. -->
	<key>LSUIElement</key>
	<false/>

	<!-- Icon (no extension). build-app.sh copies AppBundle/AppIcon.icns →
	     Contents/Resources/AppIcon.icns when present; harmless if absent. -->
	<key>CFBundleIconFile</key>
	<string>AppIcon</string>

	<!-- ============================================================
	     Document types — makes Finder double-click / "Open With" route
	     Markdown files to this app. MallowAppDelegate implements both
	     application(_:open:) and application(_:openFile:), so the OS just
	     needs to know this app claims these files.
	     ============================================================ -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Markdown Document</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<!-- Owner = this app is the primary handler for these files. -->
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>CFBundleTypeExtensions</key>
			<array>
				<string>md</string>
				<string>markdown</string>
				<string>mdown</string>
				<string>markdn</string>
			</array>
			<!-- Bind to the standard Markdown UTI + a generic text UTI so
			     files tagged either way still match. -->
			<key>LSItemContentTypes</key>
			<array>
				<string>net.daringfireball.markdown</string>
				<string>public.markdown</string>
			</array>
		</dict>
		<dict>
			<!-- Fallback: also offer to open any plain-text file (rank
			     Alternate so we never steal .txt ownership from TextEdit). -->
			<key>CFBundleTypeName</key>
			<string>Plain Text Document</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.plain-text</string>
				<string>public.text</string>
			</array>
		</dict>
	</array>

	<!-- ============================================================
	     UTType declarations. net.daringfireball.markdown is not a
	     system-declared type on every macOS version, so we both IMPORT it
	     (in case the OS knows it) and EXPORT it (so we define it if not).
	     Both conform to public.plain-text and own the same extensions.
	     ============================================================ -->
	<key>UTImportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>net.daringfireball.markdown</string>
			<key>UTTypeDescription</key>
			<string>Markdown Document</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.plain-text</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>md</string>
					<string>markdown</string>
					<string>mdown</string>
					<string>markdn</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>text/markdown</string>
				</array>
			</dict>
		</dict>
	</array>
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>net.daringfireball.markdown</string>
			<key>UTTypeDescription</key>
			<string>Markdown Document</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.plain-text</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>md</string>
					<string>markdown</string>
					<string>mdown</string>
					<string>markdn</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>text/markdown</string>
				</array>
			</dict>
		</dict>
	</array>
	<!-- ============================================================
	     Sparkle auto-update — policy + rationale in docs/security/sparkle-update-security.md.
	     ============================================================ -->
	<!-- The appcast feed — HTTPS only (condition 2). appcast.xml is committed + served via GitHub raw. -->
	<key>SUFeedURL</key>
	<string>https://raw.githubusercontent.com/gurumdeva/mallow/main/appcast.xml</string>
	<!-- EdDSA public key: every update's signature is verified against this, so a forged update can't
	     install even if the host is compromised (condition 2). The private key lives in the login Keychain. -->
	<key>SUPublicEDKey</key>
	<string>Er284WSoE1o70PHSUuI1Ml9SqaJHIiNRTYk8sKbePDk=</string>
	<!-- Verify the EdDSA signature BEFORE extracting the downloaded archive (never operate on
	     unverified bytes). This is also Sparkle's documented prerequisite for SURequireSignedFeed. -->
	<key>SUVerifyUpdateBeforeExtraction</key>
	<true/>
	<!-- Validate the appcast FEED itself, not just the enclosure (condition 2, defense in depth).
	     generate_appcast signs the feed automatically because this app declares the requirement. -->
	<key>SURequireSignedFeed</key>
	<true/>
	<!-- Check in the background once a day; the user is prompted before any download/install
	     (SUAllowsAutomaticUpdates = NO → never a silent self-replace). -->
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
	<key>SUAllowsAutomaticUpdates</key>
	<false/>
	<!-- Condition 3: NO privileged installer/downloader XPC services — the app is non-sandboxed and
	     updates by swapping the .app in /Applications, so Sparkle never needs them (staying off the
	     surface the 2025 XPC CVEs targeted). Keys intentionally OMITTED (absent ⇒ default NO). -->
</dict>
</plist>
